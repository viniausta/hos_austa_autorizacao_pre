# ============================================================
# Variáveis de ambiente — hos_austa_autorizacaopre
# Copie este arquivo para .env e preencha os valores reais.
# NUNCA versione o arquivo .env com senhas reais.
# ============================================================

# Ambiente
DEV=True

# Banco de dados Oracle  (host,porta,service_name)
AUSTA_BD_ORACLE=host.example.com,1521,ORCL
BD_USUARIO=
BD_SENHA=

# Identificação do projeto RPA no banco
UNIDADE=Hospital Austa
PROJETO=Austa Autorizacao PA
ID_UNIDADE=1001
ID_PROJETO=3
RPA_SCRIPT_NAME=HOS_Austa_AutorizacaoPre
USERNAME=robo.rpa
COD_PRESTADOR=

# Estabelecimento hospitalar (cd_estabelecimento na query)
CD_ESTABELECIMENTO=4

# Credenciais TASY (usadas no login via browser)
USUARIO_TASY=
SENHA_TASY=

# Caminhos
# Local (Windows):
#   CAMINHO_PADRAO=C:\IBMRPA\Hospital\Austa_AutorizacaoPre
# Docker: deixar em branco ou /app (pasta de trabalho do container)
CAMINHO_PADRAO=C:\IBMRPA\Hospital\Austa_AutorizacaoPre
CAMINHO_CHROME_DRIVER=C:\ProjetosPython\chromedriver.exe

# Rede de anexos
CAMINHO_REDE_ANEXO=intensicare\robo.rpa
SENHA_REDE_ANEXO=

# Backup da Guia TISS (destino para cópia do PDF gerado pelo portal)
# Local: caminho Windows | Docker: volume mapeado no container (ex: /app/backup)
CAMINHO_BACKUP_GUIA=C:\ProjetosPython\Hospital\HOS_Austa_AutorizacaoPre\GuiaAutorizacaoPrePa

# Diretório de storage do Tasy (onde o sistema TASY lê os anexos da guia)
# Local (Windows): caminho UNC  \\servidor\tasy-storage\INSURANCE_AUTHORIZATION
# Docker: /mnt/tasy-storage  (o host deve montar o share SMB e definir TASY_STORAGE_HOST_PATH no .env)
CAMINHO_TASY_STORAGE=\\servidor\tasy-storage\INSURANCE_AUTHORIZATION

# Docker — caminho no HOST onde o share SMB do Tasy está montado
# O docker-compose monta este path como /mnt/tasy-storage no container RPA
# Exemplo Linux/WSL2: TASY_STORAGE_HOST_PATH=/mnt/tasy-storage
# Deixe em branco para usar ./tasy-storage (pasta local, apenas para testes)
TASY_STORAGE_HOST_PATH=

# Oracle Instant Client (necessário apenas se banco não suporta thin mode)
ORACLE_INSTANT_CLIENT_DIR=C:\instantclient_23_9

# Notificações Zoho Cliq via OAuth2 (deixe em branco para desativar)
# Obtenha em: https://api-console.zoho.com → seu app → OAuth Credentials
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
ZOHO_REFRESH_TOKEN=
# Chat IDs dos canais de destino (visível na URL do canal no Cliq)
CLIQ_CANAL_NORMAL=
CLIQ_CANAL_ERRO=

# SMB direto — escrita no share de rede do Tasy a partir do container Linux
# Usado pelo pysmb para copiar o PDF sem precisar de drive mapeado no host.
# TASY_SMB_SERVER: IP ou hostname do servidor de arquivos
# TASY_SMB_SHARE : nome do share (sem barras)
TASY_SMB_SERVER=172.20.255.13
TASY_SMB_SHARE=tasyausta

# Selenium Remote WebDriver
# Deixe em branco para rodar localmente (modo dev com ChromeDriver local).
# Em Docker, o docker-compose.yml já define este valor automaticamente.
# Para apontar o dev local para o container Selenium:
#   SELENIUM_REMOTE_URL=http://localhost:4444/wd/hub
SELENIUM_REMOTE_URL=

# ── Integração MAEZO / CIB Seven ─────────────────────────────────────────────
# URL base do motor BPM para envio do callback de resultado da autorização.
#   Docker Compose local : MAEZO_ENGINE_REST_URL=http://cib7:8080
#   Stub de teste        : MAEZO_ENGINE_REST_URL=http://stub-cibseven:9000
#   Produção (Swarm)     : MAEZO_ENGINE_REST_URL=http://cib7:8080
MAEZO_ENGINE_REST_URL=http://stub-cibseven:9000

# Porta em que o servidor FastAPI ficará acessível (padrão: 8000)
API_PORT=8000
